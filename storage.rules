rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de verificación de identidad (DNI + selfie)
    // Solo el dueño puede subir sus propias fotos
    // Solo admin puede leerlas (desde el panel de verificaciones)
    match /verifications/{uid}/{file} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null;
    }

    // Todo lo demás bloqueado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
